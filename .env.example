# Copie ce fichier en « .env » et remplis les valeurs (local uniquement —
# sur Vercel, mets ces variables dans Settings → Environment Variables).

# Clé de chiffrement des jetons de session (longue phrase aléatoire)
MAIL_SECRET=change-moi-avec-une-longue-phrase-aleatoire

# App OAuth Google — bouton « Se connecter avec Google » (facultatif)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL publique du site (utilisée pour le retour OAuth en production)
APP_URL=

# Jeton API Gofile (facultatif — vide = envoi en invité) : les pièces jointes
# sont téléversées sur Gofile et le mail contient le lien de téléchargement
GOFILE_API_TOKEN=
